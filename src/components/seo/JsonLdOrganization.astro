---
import { site } from '../../data/site';

const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  logo: `${site.url}/media/logo-horizontal-white.png`,
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(organization)} />
