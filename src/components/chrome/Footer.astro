---
import { site, navLinks } from '../../data/site';
import { rootPath } from '../../utils/rootPath';

const logoBase = '/media/logo-horizontal-white';
const logoSrc = rootPath(`${logoBase}.png`);
const logoSrcset = [500, 800, 1080, 1600, 2000, 2600, 3200]
  .map((w) => `${rootPath(`${logoBase}-${w}.png`)} ${w}w`)
  .concat(`${logoSrc} 6174w`)
  .join(', ');
---

<footer class="footer7_component">
  <div class="padding-global">
    <div class="container-large">
      <div class="padding-bottom padding-medium">
        <div class="padding-bottom padding-medium">
          <div class="footer7_top-wrapper">
            <a
              href="index.html#header"
              id="w-node-_01b1c673-753b-abc2-cf46-8525606d7233-606d722d"
              class="footer7_logo-link w-nav-brand"
            >
              <img
                src={logoSrc}
                loading="lazy"
                sizes="119px"
                height="27"
                alt="Miri Consulting"
                srcset={logoSrcset}
              />
            </a>
            <div class="w-layout-grid footer7_link-list">
              {navLinks.map((link) => {
                const id =
                  link.label === 'Industries'
                    ? 'w-node-_1d28ec18-008b-4954-b402-e9a7d99edeb7-606d722d'
                    : link.label === 'Testimonials'
                      ? 'w-node-bd8d8176-1f60-eb7c-c62d-081e0b0578ce-606d722d'
                      : undefined;
                return (
                  <a href={link.href} id={id} class="footer7_link">{link.label}</a>
                );
              })}
            </div>
          </div>
        </div>
        <div class="line-divider"></div>
        <div class="padding-top padding-medium">
          <div class="footer7_bottom-wrapper">
            <div class="footer7_credit-text">{site.copyright}</div>
            <div class="w-layout-grid footer7_link-list">
              <a href="/privacy-policy" class="footer7_link is-secondary">Privacy Policy</a>
              <a href="/terms-of-service" class="footer7_link is-secondary">Terms of Service</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
