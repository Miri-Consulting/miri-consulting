---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { sortByOrder } from '../../utils/home/sortEntries';

const testimonials = sortByOrder(await getCollection('testimonials'));
const clientLogos = await getCollection('clientLogos');
const clientLogoBySlug = new Map(clientLogos.map((entry) => [entry.data.slug, entry]));

// Card background colors rotate by slide position: orange -> light-blue ->
// dark-blue. Applied here by index (not via :nth-child) so the runtime clones
// the native slider makes for its infinite loop carry the right color.
const cardColors = ['t-orange', 't-light-blue', 't-blue'];
---

<section class="section_testimonial23">
  <div id="testimonials" class="anchor testimonials"></div>
  <div class="padding-global">
    <div class="container-large">
      <div class="padding-section-small">
        <div class="testimonial23_component">
          <div class="margin-bottom margin-medium">
            <div class="text-align-center">
              <div class="margin-bottom margin-xxsmall">
                <h2 class="heading-style-h2 text-color-black">Customer Testimonials</h2>
              </div>
              <p class="text-size-medium text-color-grey">See what clients are saying about Miri</p>
            </div>
          </div>
        </div>

        <div class="testimonial23_carousel" data-testimonial-slider>
          <div class="testimonial23_viewport">
            <div class="testimonial23_track">
              {testimonials.map((entry, i) => {
                const {
                  quote,
                  name,
                  title,
                  company,
                  portrait,
                  portraitAlt,
                  companyLogo,
                  companyLogoAlt,
                  clientLogoSlug,
                } = entry.data;
                const fallbackLogo = clientLogoSlug
                  ? clientLogoBySlug.get(clientLogoSlug)?.data
                  : undefined;
                const clientImage = portrait ?? companyLogo ?? fallbackLogo?.logo;
                const clientImageAlt = portrait
                  ? (portraitAlt ?? name)
                  : (companyLogoAlt ?? fallbackLogo?.logoAlt ?? `${company} logo`);
                const clientImageClass = [
                  'testimonial23_customer-image',
                  portrait ? '' : 'testimonial23_logo-avatar',
                ].filter(Boolean).join(' ');
                return (
                  <div class="testimonial23_slide">
                    <div class={`testimonial23_card ${cardColors[i % cardColors.length]}`}>
                      <div class="testimonial23_content-top">
                        <div class="w-layout-vflex">
                          <div class="margin-bottom margin-small">
                            <div class="testimonial4_rating-wrapper">
                              {Array.from({ length: 5 }).map(() => (
                                <div class="testimonial4_rating-icon">
                                  <div class="icon-embed-xsmall text-color-white w-embed">
                                    <svg width="100%" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M8.16379 0.551109C8.47316 -0.183704 9.52684 -0.183703 9.83621 0.551111L11.6621 4.88811C11.7926 5.19789 12.0875 5.40955 12.426 5.43636L17.1654 5.81173C17.9684 5.87533 18.294 6.86532 17.6822 7.38306L14.0713 10.4388C13.8134 10.6571 13.7007 10.9996 13.7795 11.3259L14.8827 15.8949C15.0696 16.669 14.2172 17.2809 13.5297 16.8661L9.47208 14.4176C9.18225 14.2427 8.81775 14.2427 8.52793 14.4176L4.47029 16.8661C3.7828 17.2809 2.93036 16.669 3.11727 15.8949L4.22048 11.3259C4.29928 10.9996 4.18664 10.6571 3.92873 10.4388L0.317756 7.38306C-0.294046 6.86532 0.0315611 5.87533 0.834562 5.81173L5.57402 5.43636C5.91255 5.40955 6.20744 5.19789 6.33786 4.88811L8.16379 0.551109Z" fill="currentColor" />
                                    </svg>
                                  </div>
                                </div>
                              ))}
                            </div>
                          </div>
                          <div class="text-size-medium">{quote}</div>
                        </div>
                        <div class="margin-top margin-small">
                          <div class="testimonial23_client">
                            <div class="testimonial23_client-image-wrapper">
                              {clientImage ? (
                                <Image
                                  src={clientImage}
                                  alt={clientImageAlt}
                                  loading="lazy"
                                  class={clientImageClass}
                                />
                              ) : null}
                            </div>
                            <div class="testimonial23_client-info">
                              <div class="text-weight-semibold"><strong>{name}</strong></div>
                              <div>{title}</div>
                              <div>{company}</div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <button type="button" class="testimonial23_arrow is-prev" aria-label="Previous testimonial">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3.31066 8.75001L9.03033 14.4697L7.96967 15.5303L0.439339 8.00001L7.96967 0.469676L9.03033 1.53034L3.31066 7.25001L15.5 7.25L15.5 8.75L3.31066 8.75001Z" fill="currentColor" />
            </svg>
          </button>
          <button type="button" class="testimonial23_arrow is-next" aria-label="Next testimonial">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12.6893 7.25L6.96967 1.53033L8.03033 0.469666L15.5607 8L8.03033 15.5303L6.96967 14.4697L12.6893 8.75H0.5V7.25H12.6893Z" fill="currentColor" />
            </svg>
          </button>

          <div class="testimonial23_dots" aria-label="Testimonial navigation">
            {testimonials.map((_, i) => (
              <button
                type="button"
                class="testimonial23_dot"
                data-dot={i}
                aria-label={`Go to testimonial ${i + 1}`}
              ></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial23_carousel {
    position: relative;
  }

  .testimonial23_viewport {
    overflow: hidden;
  }

  .testimonial23_track {
    display: flex;
    flex-wrap: nowrap;
    will-change: transform;
  }

  /* Three cards per view on desktop, two on tablet, one on mobile. Override
     the legacy Webflow slider spacing so every native slide occupies one
     stable, non-overlapping slot. */
  .testimonial23_carousel .testimonial23_slide {
    flex: 0 0 33.3333%;
    max-width: 33.3333%;
    box-sizing: border-box;
    margin-right: 0;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }

  @media screen and (max-width: 991px) {
    .testimonial23_carousel .testimonial23_slide {
      flex-basis: 50%;
      max-width: 50%;
    }
  }

  @media screen and (max-width: 767px) {
    .testimonial23_carousel .testimonial23_slide {
      flex-basis: 100%;
      max-width: 100%;
      margin-right: 0;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }
  }

  /* Position-based card colors (see cardColors in the frontmatter). */
  .testimonial23_card.t-orange {
    background-color: #fa6e41;
  }
  .testimonial23_card.t-light-blue {
    background-color: #27baf9;
  }
  .testimonial23_card.t-blue {
    background-color: #3457fa;
  }

  /* Arrows: black circular buttons vertically centred over the viewport. */
  .testimonial23_arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    padding: 0;
    border: 0;
    border-radius: 100%;
    background-color: #0d0d0d;
    color: #fff;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .testimonial23_arrow:hover {
    background-color: #3457fa;
  }
  .testimonial23_arrow.is-prev {
    left: 0;
  }
  .testimonial23_arrow.is-next {
    right: 0;
  }
  .testimonial23_arrow svg {
    width: 1rem;
    height: 1rem;
    display: block;
  }

  /* Dots */
  .testimonial23_dots {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }
  .testimonial23_dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    border: 0;
    border-radius: 100%;
    background-color: rgba(13, 13, 13, 0.2);
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .testimonial23_dot:hover {
    background-color: rgba(13, 13, 13, 0.45);
  }
  .testimonial23_dot.is-active {
    background-color: #3457fa;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial23_track {
      will-change: auto;
    }
  }
</style>

<script>
  type SliderState = {
    viewport: HTMLElement;
    track: HTMLElement;
    real: HTMLElement[];
    dots: HTMLButtonElement[];
    count: number;
    spv: number;
    slideW: number;
    position: number;
    animating: boolean;
  };

  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DURATION = REDUCED ? 0 : 450;
  const EASING = 'cubic-bezier(0.4, 0, 0.2, 1)';

  function slidesPerView(): number {
    const w = window.innerWidth;
    if (w <= 767) return 1;
    if (w <= 991) return 2;
    return 3;
  }

  function initSlider(root: HTMLElement) {
    const viewport = root.querySelector<HTMLElement>('.testimonial23_viewport');
    const track = root.querySelector<HTMLElement>('.testimonial23_track');
    const prevBtn = root.querySelector<HTMLButtonElement>('.is-prev');
    const nextBtn = root.querySelector<HTMLButtonElement>('.is-next');
    const dots = Array.from(
      root.querySelectorAll<HTMLButtonElement>('.testimonial23_dot'),
    );
    if (!viewport || !track || !prevBtn || !nextBtn) return;

    const real = Array.from(
      track.querySelectorAll<HTMLElement>('.testimonial23_slide'),
    );
    const count = real.length;
    if (count === 0) return;

    const state: SliderState = {
      viewport,
      track,
      real,
      dots,
      count,
      spv: slidesPerView(),
      slideW: 0,
      position: 0,
      animating: false,
    };

    const trackIndex = (pos: number) => pos + state.spv;

    function measure() {
      const viewportWidth = state.viewport.getBoundingClientRect().width;
      state.slideW = viewportWidth > 0
        ? viewportWidth / Math.max(1, state.spv)
        : state.real[0].getBoundingClientRect().width;
    }

    function setTransform(pos: number, animate: boolean) {
      state.track.style.transition = animate && !REDUCED
        ? `transform ${DURATION}ms ${EASING}`
        : 'none';
      state.track.style.transform = `translateX(${-trackIndex(pos) * state.slideW}px)`;
      if (!animate) {
        // Force reflow so a following animated move starts from here.
        void state.track.offsetHeight;
      }
    }

    function syncDots() {
      const active = ((state.position % state.count) + state.count) % state.count;
      state.dots.forEach((dot, i) => {
        const on = i === active;
        dot.classList.toggle('is-active', on);
        if (on) dot.setAttribute('aria-current', 'true');
        else dot.removeAttribute('aria-current');
      });
    }

    function buildClones() {
      state.track
        .querySelectorAll('[data-clone]')
        .forEach((clone) => clone.remove());
      state.spv = slidesPerView();
      const lead: HTMLElement[] = [];
      const trail: HTMLElement[] = [];
      for (let i = 0; i < state.spv; i++) {
        const head = state.real[state.count - state.spv + i].cloneNode(true) as HTMLElement;
        const tail = state.real[i].cloneNode(true) as HTMLElement;
        for (const clone of [head, tail]) {
          clone.setAttribute('data-clone', '');
          clone.setAttribute('aria-hidden', 'true');
          clone
            .querySelectorAll('a, button, input')
            .forEach((el) => el.setAttribute('tabindex', '-1'));
        }
        lead.push(head);
        trail.push(tail);
      }
      lead.forEach((clone) => state.track.insertBefore(clone, state.real[0]));
      trail.forEach((clone) => state.track.appendChild(clone));
      measure();
      setTransform(state.position, false);
    }

    function finalize() {
      if (state.position >= state.count) {
        state.position -= state.count;
        setTransform(state.position, false);
      } else if (state.position < 0) {
        state.position += state.count;
        setTransform(state.position, false);
      }
      state.animating = false;
    }

    function go(delta: number) {
      if (state.animating) return;
      state.animating = true;
      state.position += delta;
      setTransform(state.position, true);
      syncDots();
      window.setTimeout(finalize, DURATION + 40);
    }

    function goTo(target: number) {
      if (state.animating) return;
      const current = ((state.position % state.count) + state.count) % state.count;
      if (target === current) return;
      state.animating = true;
      state.position = target;
      setTransform(state.position, true);
      syncDots();
      window.setTimeout(finalize, DURATION + 40);
    }

    prevBtn.addEventListener('click', () => go(-1));
    nextBtn.addEventListener('click', () => go(1));
    state.dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });

    // Lightweight swipe support.
    let startX = 0;
    let pointerDown = false;
    state.viewport.addEventListener(
      'pointerdown',
      (event) => {
        startX = (event as PointerEvent).clientX;
        pointerDown = true;
      },
    );
    window.addEventListener('pointerup', (event) => {
      if (!pointerDown) return;
      pointerDown = false;
      const dx = (event as PointerEvent).clientX - startX;
      if (Math.abs(dx) > 45) go(dx < 0 ? 1 : -1);
    });

    let resizeTimer = 0;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        if (slidesPerView() !== state.spv) {
          buildClones();
        } else {
          measure();
          setTransform(state.position, false);
        }
      }, 150);
    });

    buildClones();
    syncDots();
  }

  document
    .querySelectorAll<HTMLElement>('[data-testimonial-slider]')
    .forEach(initSlider);
</script>
