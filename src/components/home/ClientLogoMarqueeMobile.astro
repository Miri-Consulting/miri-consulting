---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { sortByOrder } from '../../utils/home/sortEntries';

const logos = sortByOrder(await getCollection('clientLogos'));
---

<section class="section_logo3 show-mobile-landscape">
  <div class="padding-section-small logo">
    <div class="w-layout-hflex logo-marquee" aria-label="Miri client and partner logos">
      {[false, true].map((ariaHidden) => (
        <div
          class="logo3_list div-block-3-copy logo-marquee-list"
          aria-hidden={ariaHidden ? 'true' : undefined}
          inert={ariaHidden ? '' : undefined}
        >
          {logos.map((entry) => {
            const { logo, logoAlt, sizeClass, externalUrl, brandClass } = entry.data;
            const baseImgClass = ['logo3_logo'];
            if (sizeClass) baseImgClass.push(sizeClass);
            if (externalUrl) {
              const anchorImgClass = [...baseImgClass, 'logo-marquee-logo'];
              if (brandClass) anchorImgClass.push(`brand-logo-${brandClass}`);
              return (
                <a
                  href={externalUrl}
                  target="_blank"
                  rel="noopener"
                  class="logo3_wrapper logo3_external-logo-link"
                >
                  <Image src={logo} alt={logoAlt} loading="lazy" class={anchorImgClass.join(' ')} />
                </a>
              );
            }
            return (
              <div class="logo3_wrapper">
                <Image src={logo} alt={logoAlt} loading="lazy" class={baseImgClass.join(' ')} />
              </div>
            );
          })}
        </div>
      ))}
    </div>
  </div>
</section>
