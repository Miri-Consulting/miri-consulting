---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { sortByOrder } from '../../utils/home/sortEntries';

const services = sortByOrder(await getCollection('services'));

// Webflow auto-generated grid-positioning IDs from the original
// services-tabs.html partial. The shared Webflow CSS rules are keyed on
// these specific IDs (e.g. `#w-node-..._4e7d9648-... { grid-area: ... }`),
// so the modal layout breaks if they're not on the rendered elements.
const SERVICES_TAB_MENU_ID = 'w-node-_9f029da8-0e02-f3b5-5061-c7de6fea06f0-f960df05';
const SERVICE_LAYOUT_IDS: Record<
  string,
  { contentTop: string; tabsMenu: string; firstTabLink?: string }
> = {
  operations: {
    contentTop: 'w-node-b213a889-87f7-799e-0213-ce76cc48abb3-f960df05',
    tabsMenu: 'w-node-b213a889-87f7-799e-0213-ce76cc48abba-f960df05',
  },
  finance: {
    contentTop: 'w-node-_4e7d9648-627f-8a6e-8553-79054c6acf29-f960df05',
    tabsMenu: 'w-node-_4e7d9648-627f-8a6e-8553-79054c6acf30-f960df05',
    firstTabLink: 'w-node-_4e7d9648-627f-8a6e-8553-79054c6acf31-f960df05',
  },
  digital: {
    contentTop: 'w-node-_1bb9774c-6bdf-da35-81c4-8420db444470-f960df05',
    tabsMenu: 'w-node-_1bb9774c-6bdf-da35-81c4-8420db444477-f960df05',
    firstTabLink: 'w-node-_1bb9774c-6bdf-da35-81c4-8420db444478-f960df05',
  },
  hr: {
    contentTop: 'w-node-_9d6a1ab8-7f22-e685-a085-f4b0559bb487-f960df05',
    tabsMenu: 'w-node-_9d6a1ab8-7f22-e685-a085-f4b0559bb48e-f960df05',
    firstTabLink: 'w-node-_9d6a1ab8-7f22-e685-a085-f4b0559bb48f-f960df05',
  },
};
---

<section class="section_layout507">
  <div id="services" class="anchor services"></div>
  <div class="padding-global">
    <div class="container-medium">
      <div class="padding-section-medium">
        <div class="layout507_component">
          <div class="margin-bottom margin-xlarge">
            <div class="text-align-center">
              <div class="margin-bottom margin-xxsmall">
                <h2 class="heading-style-h2">Our Services</h2>
              </div>
              <p class="text-size-medium-smallspace text-color-grey">
                We offer specialized teams to support each of the core pillars of your business.
              </p>
            </div>
          </div>
          <div
            data-duration-in="400"
            data-duration-out="200"
            data-current="Tab 1"
            data-easing="ease"
            class="layout507_tabs w-tabs"
          >
            <div id={SERVICES_TAB_MENU_ID} class="layout507_tabs-menu w-tab-menu">
              {services.map((entry, i) => (
                <a
                  data-w-tab={`Tab ${i + 1}`}
                  ms-code-onhover="click"
                  class={`layout507_tab-link w-inline-block w-tab-link${i === 0 ? ' w--current' : ''}`}
                >
                  <h3 class="heading-style-h6">{entry.data.name}</h3>
                </a>
              ))}
            </div>
            <div class="layout507_tabs-content w-tab-content">
              {services.map((entry, i) => {
                const openAttr = entry.data.legacyModalId.replace(/^modal/, 'open');
                return (
                  <div
                    data-w-tab={`Tab ${i + 1}`}
                    class={`layout507_tab-pane w-tab-pane${i === 0 ? ' w--tab-active' : ''}`}
                  >
                    <div class="layout507_card">
                      <div class="layout507_image-wrapper">
                        <Image
                          src={entry.data.cardImage}
                          alt={entry.data.cardImageAlt}
                          loading="lazy"
                          class="layout507_image"
                        />
                      </div>
                      <div class="layout507_card-content center">
                        <div class="layout507_card-content-top">
                          <div class="margin-bottom margin-small">
                            <h3 class="heading-style-h3">{entry.data.cardHeading}</h3>
                          </div>
                          <p class="text-size-medium text-color-grey">{entry.data.cardBody}</p>
                        </div>
                        <div class="margin-top margin-medium">
                          <div class="button-group">
                            <a
                              fs-modal-element={openAttr}
                              href="index.html#"
                              class="button-2 is-black w-inline-block"
                            >
                              <div>Learn more</div>
                            </a>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{services.map((entry) => {
  const modalAttr = entry.data.legacyModalId;
  const closeAttr = modalAttr.replace(/^modal/, 'close');
  const layoutIds = SERVICE_LAYOUT_IDS[entry.data.slug];
  return (
    <div fs-modal-element={modalAttr} class="fs_modal-1_popup-2 ramel service-modal-popup">
      <div fs-modal-element={closeAttr} class="fs_modal-1_cover-2">
        <div fs-modal-element={closeAttr} class="fs_modal-1_close-2">
          <div class="fs_modal-1_close-icon-2 w-embed">
            <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" viewBox="0 0 24 24">
              <path
                fill="CurrentColor"
                d="M14.5,12l9-9c0.7-0.7,0.7-1.8,0-2.5c-0.7-0.7-1.8-0.7-2.5,0l-9,9l-9-9c-0.7-0.7-1.8-0.7-2.5,0 c-0.7,0.7-0.7,1.8,0,2.5l9,9l-9,9c-0.7,0.7-0.7,1.8,0,2.5c0.7,0.7,1.8,0.7,2.5,0l9-9l9,9c0.7,0.7,1.8,0.7,2.5,0 c0.7-0.7,0.7-1.8,0-2.5L14.5,12z"
              />
            </svg>
          </div>
        </div>
      </div>
      <div class="fs_modal-1_wrapper-2 people service-modal">
        <div id={layoutIds?.contentTop} class="layout507_card-content-top">
          <div class="margin-bottom margin-small">
            <h2 class="heading-style-h3">{entry.data.modalHeading}</h2>
          </div>
          <p class="text-size-medium-smallspace text-color-grey">{entry.data.modalSubheading}</p>
        </div>
        <div class="layout507_card-content">
          <div
            data-duration-in="400"
            data-duration-out="200"
            data-current="Tab 1"
            data-easing="ease"
            class="layout493_tabs w-tabs"
          >
            <div id={layoutIds?.tabsMenu} class="layout493_tabs-menu w-tab-menu">
              {entry.data.subServices.map((sub, i) => (
                <a
                  data-w-tab={`Tab ${i + 1}`}
                  ms-code-onhover="click"
                  id={i === 0 ? layoutIds?.firstTabLink : undefined}
                  class={`layout493_tab-link w-inline-block w-tab-link${i === 0 ? ' w--current' : ''}`}
                >
                  <h3 class="heading-style-h6">{sub.title}</h3>
                  <div class="layout493_paragraph">
                    <div class="margin-top margin-xxsmall">
                      <p class="text-size-small text-color-grey">{sub.description}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
            <div class="layout493_tabs-content w-tab-content">
              {entry.data.subServices.map((_, i) => (
                <div
                  data-w-tab={`Tab ${i + 1}`}
                  class={`layout493_tab-pane w-tab-pane${i === 0 ? ' w--tab-active' : ''}`}
                />
              ))}
            </div>
          </div>
        </div>
        <div class="layout507_image-wrapper">
          <Image
            src={entry.data.cardImage}
            alt={entry.data.modalImageAlt}
            loading="lazy"
            class="layout507_image"
          />
        </div>
      </div>
    </div>
  );
})}
