---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { sortByOrder } from '../../utils/home/sortEntries';
import { site } from '../../data/site';
import { rootPath } from '../../utils/rootPath';

const team = sortByOrder(await getCollection('team'));
const arrowIconSrc = rootPath('/media/arrow-up-right.svg');
const joinTeamUrl = site.joinTeamFormUrl;
---

<section class="section_team8">
  <div id="people" class="anchor industries"></div>
  <div class="padding-global">
    <div class="container-medium">
      <div class="padding-section-small">
        <div class="team8_component">
          <div class="margin-bottom margin-xlarge">
            <div class="text-align-center">
              <div class="margin-bottom margin-xxsmall">
                <h2 class="heading-style-h2">The People Behind Miri</h2>
              </div>
              <div class="w-layout-vflex margin-bottom margin-xsmall">
                <p class="text-size-medium text-color-grey">We're always looking for great talent.</p>
              </div>
              <a href={joinTeamUrl} class="button-2 is-secondary w-inline-block">
                <div>Join our team</div>
              </a>
            </div>
          </div>
          <div class="team8_list-wrapper">
            <div class="w-layout-grid team8_list">
              {team.map((entry) => {
                const openId = entry.data.legacyModalId.replace(/^modal/, 'open');
                return (
                  <a
                    fs-modal-element={openId}
                    href="#"
                    class="team8_item w-inline-block"
                  >
                    <div class="team8_image-wrapper">
                      <Image
                        src={entry.data.headshot}
                        alt={entry.data.headshotAlt}
                        loading="lazy"
                        class="team8_image"
                      />
                    </div>
                    <div class="team8_title-wrapper">
                      <div class="w-layout-vflex margin-bottom margin-tiny">
                        <div class="text-size-small text-weight-semibold">{entry.data.name}</div>
                      </div>
                      <div class="text-size-tiny">{entry.data.roleLabel}</div>
                    </div>
                    <img loading="lazy" height="Auto" alt="" src={arrowIconSrc} class="icon-1x1-medium" />
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
