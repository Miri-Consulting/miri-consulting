---
import RawHtml from '../components/RawHtml.astro';
import NavBar from '../components/chrome/NavBar.astro';
import Footer from '../components/chrome/Footer.astro';
import HeadAnalytics from '../components/analytics/HeadAnalytics.astro';
import { rewriteAssetPaths } from '../utils/rewriteAssetPaths';
import { sanitizeLegalHead } from '../utils/sanitizeLegalHead';
import { site, webflow } from '../data/site';
import inlineGlobals from '../styles/inline-globals.css?raw';
import staticOverrides from '../styles/miri-static-overrides.css?raw';
import bodyScripts from '../partials/body-scripts-home.html?raw';

interface Props {
  canonicalPath: string;
  bodyClass: string;
  bodyHtml: string;
  headHtml: string;
  webflowPageId: string;
}

const { canonicalPath, bodyClass, bodyHtml, headHtml, webflowPageId } = Astro.props;
const canonical = new URL(canonicalPath, site.url).href;
const head = sanitizeLegalHead(rewriteAssetPaths(headHtml))
  .replace(/<meta content="[^"]*" name="google-site-verification"\/>/, '')
  .replace(
    /(families:\s*\[[^\]]+\])(\s*\}\s*\}\);)/,
    "$1, display: 'swap'$2",
  )
  .replace(/<link href="[^"]+" rel="canonical"\/>/, `<link href="${canonical}" rel="canonical"/>`)
  .replace(
    '<meta content="width=device-width, initial-scale=1" name="viewport"/>',
    '<meta content="width=device-width, initial-scale=1" name="viewport"/><meta content="index,follow" name="robots"/>',
  );
---

<!DOCTYPE html>
<html
  lang="en"
  data-wf-domain={webflow.domain}
  data-wf-page={webflowPageId}
  data-wf-site={webflow.siteId}
>
  <head>
    <Fragment set:html={head} />
    <HeadAnalytics />
  </head>
  <body class={bodyClass}>
    <div class="page-wrapper">
      <div class="global-styles w-embed">
        <style is:inline is:global set:html={inlineGlobals}></style>
        <style is:inline is:global set:html={staticOverrides}></style>
      </div>
      <main class="main-wrapper">
        <NavBar variant="legal" />
        <RawHtml html={bodyHtml} />
        <Footer />
      </main>
    </div>
    <RawHtml html={bodyScripts} />
  </body>
</html>
